@{
    ViewData["Title"] = "Huş Mühendislik";
}

<!-- =====================
     HERO SECTION
======================== -->
<section id="hero" class="hus-hero">
    <video class="hus-hero__video hus-hero__video--desktop" autoplay muted playsinline preload="auto">
        <source src="~/videos/hero-video.mp4" type="video/mp4" />
    </video>
    <video class="hus-hero__video hus-hero__video--mobile" autoplay muted playsinline preload="auto">
        <source src="~/videos/hero-video-mobil.mp4" type="video/mp4" />
    </video>
    <div class="hus-hero__overlay"></div>
    <div class="hus-hero__scroll-cue" onclick="scrollToSection(null,'about')">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
        </svg>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var video = document.querySelector('.hus-hero__video');
        var hasScrolled = false;

        function doAutoScroll() {
            if (hasScrolled) return;
            hasScrolled = true;
            var about = document.getElementById('about');
            if (about) {
                window.scrollTo({ top: about.offsetTop - 70, behavior: 'smooth' });
            }
        }

        video.addEventListener('ended', doAutoScroll);
        video.addEventListener('timeupdate', function () {
            if (video.duration && video.currentTime >= video.duration - 0.3) doAutoScroll();
        });

        window.addEventListener('scroll', function () {
            if (window.pageYOffset < 50) {
                hasScrolled = false;
                video.currentTime = 0;
                video.play();
            }
        });
    });
</script>

<style>
    /* =====================
       HERO
    ======================== */
    .hus-hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 100px 40px 100px;
        text-align: center;
    }

    .hus-hero__video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        z-index: 0;
        pointer-events: none;
    }

    .hus-hero__video--desktop { display: block; }
    .hus-hero__video--mobile  { display: none; }

    @@media (max-width: 768px) {
        .hus-hero__video--desktop { display: none; }
        .hus-hero__video--mobile  { display: block; }
    }

    .hus-hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to bottom, rgba(0,0,0,0.35) 0%, rgba(0,0,0,0.50) 60%, rgba(0,0,0,0.65) 100%);
        z-index: 1;
        pointer-events: none;
    }

    .hus-hero__scroll-cue {
        position: absolute;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 2;
        color: rgba(255,255,255,0.65);
        cursor: pointer;
        animation: heroScrollBounce 2s ease-in-out infinite;
        transition: color 0.2s;
    }

    .hus-hero__scroll-cue:hover { color: #d4a843; }

    @@keyframes heroScrollBounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50%       { transform: translateX(-50%) translateY(6px); }
    }

    @@media (max-width: 640px) {
        .hus-hero {
            padding: 90px 20px 80px;
            width: 100vw;
            margin-left: calc(-50vw + 50%);
            position: relative;
        }

        .hus-hero__video {
            object-position: center center;
        }
    }

    /* =====================
       ABOUT SECTION
    ======================== */
    .about-content-wrapper {
        display: flex;
        gap: 40px;
        align-items: center;
    }

    .about-image-side {
        flex: 1;
    }

    .about-image {
        width: 100%;
        border-radius: 10px;
        object-fit: cover;
    }

    .about-text-side {
        flex: 1;
    }

    @@media (max-width: 768px) {
        .about-content-wrapper {
            flex-direction: column;
        }

        .about-image-side {
            width: 100%;
        }

        div[id="services"].about-container {
            padding: 60px 20px !important;
        }
    }

    /* =====================
       SERVICE PANELS
    ======================== */
    .services-panel-container {
        display: flex;
        gap: 16px;
    }

    .service-panel {
        flex: 1;
        cursor: pointer;
    }

    .panel-image {
        position: relative;
        overflow: hidden;
        border-radius: 10px;
        aspect-ratio: 3/4;
    }

    .panel-image img {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.3s ease;
    }

    .service-panel:hover .panel-image img { transform: scale(1.05); }

    .panel-overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(to top, rgba(0,0,0,0.7) 0%, transparent 60%);
    }

    .panel-title {
        position: absolute;
        bottom: 16px;
        left: 0;
        right: 0;
        text-align: center;
        color: #ffffff;
        font-size: 16px;
        font-weight: 700;
        letter-spacing: 2px;
    }

    @@media (max-width: 768px) {
        .services-panel-container {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .panel-image {
            aspect-ratio: 1/1;
        }

        .panel-title {
            font-size: 13px;
        }

        div[id="about"].about-container {
            padding: 60px 20px !important;
        }
    }

    /* =====================
       SERVICE SECTIONS
    ======================== */
    .service-content-wrapper {
        display: flex;
        gap: 40px;
        align-items: center;
    }

    .service-text-side {
        flex: 1;
    }

    .service-image-side {
        flex: 1;
    }

    .service-side-image {
        width: 100%;
        border-radius: 10px;
        object-fit: cover;
        max-height: 400px;
    }

    @@media (max-width: 768px) {
        .service-content-wrapper {
            flex-direction: column !important;
        }

        /* Çevre ve Maden'de resim solda — mobilde her zaman önce resim */
        .service-content-wrapper .service-image-side {
            order: -1;
            width: 100%;
        }

        .service-side-image {
            max-height: 220px;
            width: 100%;
        }

        .service-section {
            padding: 30px 20px;
        }
    }

    /* =====================
       REFERENCES
    ======================== */
    .logo-showcase {
        display: flex;
        flex-direction: column;
        gap: 20px;
    }

    .logo-row {
        display: flex;
        justify-content: center;
        align-items: center;
        gap: 20px;
        flex-wrap: wrap;
    }

    .logo-item {
        display: flex;
        align-items: center;
        justify-content: center;
    }

    .logo-item img {
        max-height: 60px;
        max-width: 120px;
        object-fit: contain;
        filter: grayscale(100%);
        opacity: 0.7;
        transition: all 0.2s ease;
    }

    .logo-item img:hover {
        filter: grayscale(0%);
        opacity: 1;
    }

    @@media (max-width: 768px) {
        .logo-row {
            gap: 16px;
        }

        .logo-item img {
            max-height: 40px;
            max-width: 80px;
        }

        .references-container {
            padding: 60px 20px;
        }
    }

    /* =====================
       CONTACT
    ======================== */
    .map-contact-content {
        display: flex;
        gap: 40px;
    }

    .map-column {
        flex: 1;
    }

    .map-container {
        height: 400px;
        border-radius: 10px;
        overflow: hidden;
    }

    .contact-info-column {
        flex: 1;
    }

    @@media (max-width: 768px) {
        .map-contact-content {
            flex-direction: column;
        }

        .map-container {
            height: 250px;
        }

        .map-contact-container {
            padding: 60px 20px;
        }

        .office-tabs {
            display: flex;
            gap: 8px;
        }

        .office-tab {
            flex: 1;
            font-size: 11px;
            padding: 8px 4px;
        }
    }
</style>

<!-- About Us Section -->
<div id="about" class="about-container" style="padding: 80px 40px; min-height: 600px;">
    <div class="section-title">
        <h2>Hakkımızda</h2>
    </div>
    <div class="about-content">
        <div class="about-content-wrapper">
            <div class="about-image-side">
                <img src="~/images/about-company.jpg" alt="Huş Mühendislik Hakkında" class="about-image">
            </div>
            <div class="about-text-side">
                <p class="about-text">
                    1994 yılında Orman Yüksek Mühendisi Şahap Agas ile Orman Mühendisi Murat Uçum tarafından, <strong>orman arazilerinin tahsisi konularında müşavirlik-mühendislik, ağaçlandırma-peyzaj konularında ise proje ve mühendislik</strong> hizmeti vermek üzere kurulmuştur.
                </p>
                <p class="about-text">
                    O tarihten bu yana sektörde hizmet veren firma, orman izin dosyası, özel ağaçlandırma proje ve uygulaması ve <strong>ÇED-proje tanıtım dosyası ile orman arazilerinin tahsisi ve özel ağaçlandırma proje ve uygulama</strong> konularında sektörde lider, <strong>sanayicilerin/yatırımcıların/madencilerin çevre mevzuatı</strong> konularında güvenilir bir çözüm ortağı olarak faaliyetlerine devam etmektedir.
                </p>
                <div class="about-timeline">
                    <div class="timeline-item">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content"><h4>1994</h4><p>Şirket kuruluşu</p></div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content"><h4>30+ Yıl</h4><p>Sektör deneyimi</p></div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content"><h4>50+</h4><p>Tamamlanan proje</p></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

