                    <div class="timeline-item">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <h4>1994</h4>
                            <p>Şirket kuruluşu</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <h4>30+ Yıl</h4>
                            <p>Sektör deneyimi</p>
                        </div>
                    </div>
                    <div class="timeline-item">
                        <div class="timeline-marker"></div>
                        <div class="timeline-content">
                            <h4>50+</h4>
                            <p>Tamamlanan proje</p>
                        </div>
                </div>
            </div>
        </div>
    </div>
</div>

