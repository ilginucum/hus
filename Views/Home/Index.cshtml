@{
    ViewData["Title"] = "Huş Mühendislik";
}

<!-- =====================
     HERO SECTION
======================== -->
<section id="hero" class="hus-hero">

    <!-- Background video -->
    <video class="hus-hero__video"
           autoplay
           muted
           playsinline
           preload="auto">
        <source src="~/videos/hero-video.mp4" type="video/mp4" />
    </video>

    <!-- Dark overlay over video -->
    <div class="hus-hero__overlay"></div>

    

    <!-- Scroll cue -->
    <div class="hus-hero__scroll-cue" onclick="scrollToSection(null,'about')">
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="6 9 12 15 18 9"/>
        </svg>
    </div>
</section>

<script>
    document.addEventListener('DOMContentLoaded', function () {
        var video = document.querySelector('.hus-hero__video');
        var hasScrolled = false;

        function doAutoScroll() {
            if (hasScrolled) return;
            hasScrolled = true;
            var about = document.getElementById('about');
            if (about) {
                window.scrollTo({
                    top: about.offsetTop - 70,
                    behavior: 'smooth'
                });
            }
        }

        /* Video bitince scroll */
        video.addEventListener('ended', doAutoScroll);

        /* Fallback: video süresinin %99'una gelince scroll */
        video.addEventListener('timeupdate', function () {
            if (video.duration && video.currentTime >= video.duration - 0.3) {
                doAutoScroll();
            }
        });

        /* Kullanıcı hero'ya geri dönünce videoyu baştan oynat */
        window.addEventListener('scroll', function () {
            if (window.pageYOffset < 50) {
                hasScrolled = false;
                video.currentTime = 0;
                video.play();
            }
        });
    });
</script>

<style>
    /* =====================
       HERO — VIDEO BG
    ======================== */
    .hus-hero {
        position: relative;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        padding: 100px 40px 100px;
        text-align: center;
    }

    /* Full-cover background video */
    .hus-hero__video {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
        z-index: 0;
        pointer-events: none;
    }

    /* Dark overlay so content is readable */
    .hus-hero__overlay {
        position: absolute;
        inset: 0;
        background: linear-gradient(
            to bottom,
            rgba(0, 0, 0, 0.35) 0%,
            rgba(0, 0, 0, 0.50) 60%,
            rgba(0, 0, 0, 0.65) 100%
        );
        z-index: 1;
        pointer-events: none;
    }

    .hus-hero__content {
        position: relative;
        z-index: 2;
        display: flex;
        flex-direction: column;
        align-items: center;
        max-width: 640px;
        width: 100%;
    }

    /* Logo */
    .hus-hero__logo-wrap {
        margin-bottom: 48px;
    }

    .hus-hero__logo {
        height: clamp(120px, 20vw, 220px);
        width: auto;
        max-width: 480px;
        object-fit: contain;
        /* drop-shadow so logo pops on any video frame */
        filter: drop-shadow(0 2px 24px rgba(0,0,0,0.45));
    }

    /* Stats — semi-transparent dark card */
    .hus-hero__stats {
        display: flex;
        align-items: stretch;
        background: rgba(255, 255, 255, 0.12);
        border: 1px solid rgba(255, 255, 255, 0.25);
        border-radius: 12px;
        overflow: hidden;
        backdrop-filter: blur(8px);
        -webkit-backdrop-filter: blur(8px);
        margin-bottom: 44px;
    }

    .hus-hero__stat {
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 20px 36px;
        gap: 5px;
    }

    .hus-hero__stat-divider {
        width: 1px;
        background: rgba(255, 255, 255, 0.25);
        align-self: stretch;
    }

    .hus-hero__stat-num {
        font-family: 'Playfair Display', serif;
        font-size: 30px;
        font-weight: 700;
        color: #d4a843;
        line-height: 1;
    }

    .hus-hero__stat-label {
        font-family: 'Open Sans', sans-serif;
        font-size: 10px;
        font-weight: 500;
        color: rgba(255, 255, 255, 0.80);
        text-transform: uppercase;
        letter-spacing: 1.5px;
        white-space: nowrap;
    }

    /* Buttons */
    .hus-hero__buttons {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 14px;
        width: 100%;
    }

    .hus-btn {
        display: inline-flex;
        align-items: center;
        gap: 7px;
        font-family: 'Open Sans', sans-serif;
        font-size: 12.5px;
        font-weight: 600;
        letter-spacing: 0.5px;
        padding: 12px 26px;
        border-radius: 8px;
        text-decoration: none;
        cursor: pointer;
        transition: all 0.2s ease;
        border: 1.5px solid transparent;
    }

    .hus-btn--outline {
        background: rgba(255,255,255,0.1);
        color: #ffffff;
        border-color: rgba(255,255,255,0.6);
        backdrop-filter: blur(4px);
    }

    .hus-btn--outline:hover {
        background: rgba(255,255,255,0.25);
        color: #ffffff;
    }

    .hus-btn--gold {
        background: #d4a843;
        color: #ffffff;
        border-color: #d4a843;
    }

    .hus-btn--gold:hover {
        background: #b8902e;
        border-color: #b8902e;
        color: #ffffff;
    }

    /* Scroll cue */
    .hus-hero__scroll-cue {
        position: absolute;
        bottom: 28px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 2;
        color: rgba(255,255,255,0.65);
        cursor: pointer;
        animation: heroScrollBounce 2s ease-in-out infinite;
        transition: color 0.2s;
    }

    .hus-hero__scroll-cue:hover { color: #d4a843; }

    @@keyframes heroScrollBounce {
        0%, 100% { transform: translateX(-50%) translateY(0); }
        50%       { transform: translateX(-50%) translateY(6px); }
    }

    /* Responsive */
    @@media (max-width: 640px) {
        .hus-hero { padding: 90px 20px 80px; }
        .hus-hero__stat { padding: 16px 20px; }
        .hus-hero__stat-label { font-size: 9px; letter-spacing: 0.8px; }
        .hus-hero__stat-num { font-size: 24px; }
        .hus-btn { justify-content: center; width: 100%; }
    }
</style>


<!-- About Us Section -->
<div id="about" class="about-container" style="padding: 80px 40px; min-height: 600px;">
    <!-- Section Title -->
    <div class="section-title">
        <h2>Hakkımızda</h2>
    </div>
    
    <!-- About Us Content -->
    <div class="about-content">
        <div class="about-content-wrapper">
            <div class="about-image-side">
                <img src="~/images/about-company.jpg" alt="Huş Mühendislik Hakkında" class="about-image">
            </div>
            <div class="about-text-side">
                <p class="about-text">
                    1994 yılında Orman Yüksek Mühendisi Şahap Agas ile Orman Mühendisi Murat Uçum tarafından, <strong>orman arazilerinin tahsisi konularında müşavirlik-mühendislik, ağaçlandırma-peyzaj konularında ise proje ve mühendislik</strong> hizmeti vermek üzere kurulmuştur.
                </p>
                <p class="about-text">
                    O tarihten bu yana sektörde hizmet veren firma, orman izin dosyası, özel ağaçlandırma proje ve uygulaması ve <strong>ÇED-proje tanıtım dosyası ile orman arazilerinin tahsisi ve özel ağaçlandırma proje ve uygulama</strong> konularında sektörde lider, <strong>sanayicilerin/yatırımcıların/madencilerin çevre mevzuatı</strong> konularında güvenilir bir çözüm ortağı olarak faaliyetlerine devam etmektedir.
                </p>
                
                <!-- Timeline/Achievements -->
